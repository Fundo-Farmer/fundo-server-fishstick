PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/fundo
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
UPLOAD_DIR=src/uploads
# First super admin created automatically on first boot if no users exist
BOOTSTRAP_ADMIN_EMAIL=admin@fundo.africa
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_NAME=Fundo Admin

# Payments (sandbox providers — see README "Payments architecture" for going live)
PLATFORM_COMMISSION_PERCENT=6
MOCK_PAYMENT_DELAY_MS=6000

# Delivery pricing tiers (see README "Logistics" section)
LOCAL_DELIVERY_RADIUS_KM=15
LOCAL_DELIVERY_BASE_FEE=2000
LOCAL_DELIVERY_FEE_PER_KM=500
LONG_HAUL_DELIVERY_BASE_FEE=15000
LONG_HAUL_DELIVERY_FEE_PER_KM=800
DELIVERY_FALLBACK_FEE=5000
LONG_HAUL_KM_PER_DAY=400
MAX_DELIVERY_REASSIGNMENTS=3
MAX_SUBSCRIPTION_SKIPS=3

# Monetization (see README "Analytics & monetization" section)
FEATURED_LISTING_FEE=10000
FEATURED_LISTING_DAYS=7
PREMIUM_MONTHLY_FEE=50000
PREMIUM_COMMISSION_PERCENT=3
PREMIUM_MAX_FAILURES=2
